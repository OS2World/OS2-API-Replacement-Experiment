# GLOCMRI_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: GLOCMRI.DLL
GLOCMRI.DLL: GLOCMRI.OBJ GLOCMRI.LNK
	$(LINK) @GLOCMRI.LNK
	@echo Build complete: GLOCMRI.DLL
GLOCMRI.OBJ: GLOCMRI.C
	$(CC) $(CFLAGS) -fo=GLOCMRI.OBJ GLOCMRI.C
clean: .SYMBOLIC
	-$(RM) GLOCMRI.OBJ 2>NUL
	-$(RM) GLOCMRI.DLL 2>NUL
	-$(RM) GLOCMRI.MAP 2>NUL
