# PMSPL.LNK -- OpenWatcom WLINK for PMSPL.DLL (32-bit stub)
#
# Build:
#   wcc386 -bt=OS2 -bm -wx -s -fo=PMSPL.OBJ PMSPL.C
#   wlink @PMSPL.LNK

SYSTEM os2v2 dll initinstance

NAME PMSPL.DLL

FILE PMSPL.OBJ

OPTION ELIMINATE
OPTION OSNAME='OS/2 and ArcaOS'
OPTION DESCRIPTION 'PM Spooler Dynalink'
OPTION MAP=PMSPL.MAP

