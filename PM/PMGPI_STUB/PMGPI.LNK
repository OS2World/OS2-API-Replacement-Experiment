# PMGPI.LNK -- OpenWatcom WLINK for PMGPI.DLL (32-bit stub)
#
# Build:
#   wcc386 -bt=OS2 -bm -6s -sg -wx -s -fo=PMGPI.OBJ PMGPI.C
#   wlink @PMGPI.LNK

SYSTEM os2v2 dll initinstance

NAME PMGPI.DLL

FILE PMGPI.OBJ

# OS/2 API import library -- resolves Dos* used by the -dPMGPI_LOG call
# logging (DosOpen/DosWrite/DosSetFilePtr/DosClose). Harmless for the
# normal build: an import library only contributes referenced symbols.
LIBRARY os2386

# Force import table entries matching original PMGPI.DLL dependency chain
IMPORT _pmgre_ref    PMGRE.1
IMPORT _pmwin_ref    PMWIN.748
IMPORT _dos_ref      DOSCALLS.257
IMPORT _vio_ref      VIOCALLS.30

OPTION DESCRIPTION 'Gpi functions and 32-bit thunks'
OPTION MAP=PMGPI.MAP

# Resident name
# (module name 'pmgpi' ord 0 is automatic from NAME directive)

# Non-resident exports -- all 298 functions
# Ordinals match the original PMGPI.DLL exactly.
# Internal symbol names use the #pragma aux-pinned names (all caps).

