# PMGRE.LNK -- cWarp PMGRE clone: REAL LX forwarders to PMMERGE (wlink).
# IMPORT <sym> PMMERGE.<ord>  +  EXPORT <name>.<origord> = <sym>  => wlink emits a
# type-0x04 forwarder (zero code, bitness preserved). 78 exports (78 named).

SYSTEM os2v2 dll initinstance terminstance
NAME PMGRE.DLL
FILE PMGRE.OBJ
OPTION MANYAUTODATA
OPTION DESCRIPTION 'cWarp PMGRE - forwarders to PMMERGE'
OPTION MAP=PMGRE.MAP

# imports (one per distinct PMMERGE target ordinal)
