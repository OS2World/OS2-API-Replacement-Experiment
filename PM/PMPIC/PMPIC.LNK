# PMPIC.LNK -- OpenWatcom WLINK for PMPIC.DLL (32-bit stub)
#
# Build:
#   wcc386 -bt=OS2 -bm -wx -s -fo=PMPIC.OBJ PMPIC.C
#   wlink @PMPIC.LNK
#
# Ordinal gaps 5-10 are intentional (not assigned in original binary).

SYSTEM os2v2 dll initinstance

NAME PMPIC.DLL

FILE PMPIC.OBJ

# Force import table entries matching original PMPIC.DLL dependency chain
IMPORT _dos_ref      DOSCALLS.257
IMPORT _pmgpi_ref    PMGPI.1
IMPORT _pmwin_ref    PMWIN.748
IMPORT _nls_ref      NLS.1112
IMPORT _pmshapi_ref  PMSHAPI.1
IMPORT _pmspl_ref    PMSPL.1
IMPORT _pmmerge_ref  PMMERGE.1
IMPORT _msg_ref      MSG.1

OPTION DESCRIPTION 'PMPIC Dynalink'
OPTION MAP=PMPIC.MAP

EXPORT PicPrint.1
EXPORT PicIchg.2
EXPORT Pif2Met.3
EXPORT PrfPif2Met.4
EXPORT Pic32Print.11
EXPORT Pic32Ichg.12
EXPORT Prf32Pif2Met.13
