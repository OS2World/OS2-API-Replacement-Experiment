        COMBOBOX     "",           DID_STYLE,              3,  21, 158, 70,
                     CBS_SIMPLE | WS_GROUP | WS_TABSTOP
        LTEXT        "Size",       DID_SIZE_PREFIX,      166, 110,  63,  8
        COMBOBOX     "",           DID_SIZE,             166,  35,  66, 75,
                     CBS_SIMPLE | WS_GROUP | WS_TABSTOP
        AUTOCHECKBOX "~Display",   DID_DISPLAY_FILTER,   170,  85,  50, 10,
                     WS_GROUP | WS_TABSTOP
        AUTOCHECKBOX "~Printer",   DID_PRINTER_FILTER,   170,  75,  50, 10
        GROUPBOX     "Emphasis",   DID_EMPHASIS_GROUPBOX, 166, 27,  66, 40
        AUTOCHECKBOX "Out~line",   DID_OUTLINE,          170,  49,  59, 10
        AUTOCHECKBOX "~Underline", DID_UNDERSCORE,       170,  39,  59, 10
        AUTOCHECKBOX "~Strikeout", DID_STRIKEOUT,        170,  29,  59, 10
        DEFPUSHBUTTON "~OK",       DID_OK,                 3,   2,  45, 13,
                     WS_GROUP | WS_TABSTOP
        PUSHBUTTON   "Cancel",     DID_CANCEL,            49,   2,  45, 13
        PUSHBUTTON   "Help",       DID_HELP_BUTTON,       95,   2,  45, 13,
                     BS_HELP | BS_NOPOINTERFOCUS
        PUSHBUTTON   "~Apply",     DID_APPLY_BUTTON,     141,   2,  45, 13
        PUSHBUTTON   "~Reset",     DID_RESET_BUTTON,     187,   2,  45, 13
        GROUPBOX     "Sample",     DID_SAMPLE_GROUPBOX,    3,  27, 158, 33
        LTEXT        "abcdABCD",   DID_SAMPLE,             4,  28, 154, 24
        LTEXT        "Font may not be ISO-compliant", DID_FONT_ISO_UNTESTED, 5, 17, 230, 8
        COMBOBOX     "",           IDC_FONT_COLOR_CB,      3,  17, 158, 54,
                     CBS_DROPDOWNLIST | WS_GROUP | WS_TABSTOP
        LTEXT        "Color",      IDC_FONT_COLOR_TXT,     3,  71,  42,  8
    END
END

