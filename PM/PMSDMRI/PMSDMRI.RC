/* ================================================================== */
/*  File Open / Save-As dialog  (DID_FILE_DIALOG = 256)                */
/* ================================================================== */
/* Geometry, control set, ids, classes and styles reconstructed to match the
 * original template (dialog 319x185, 16 controls). Read from structure, not
 * copied bytes. */
DLGTEMPLATE DID_FILE_DIALOG LOADONCALL MOVEABLE DISCARDABLE
BEGIN
    DIALOG  "Open", DID_FILE_DIALOG, 6, 4, 319, 185,
            FS_NOBYTEALIGN | WS_CLIPSIBLINGS | WS_SAVEBITS,
            FCF_TITLEBAR | FCF_SYSMENU | FCF_DLGBORDER
    BEGIN
        LTEXT        "Open filename:",      DID_FILENAME_TXT,        3, 174,  96,  8
        ENTRYFIELD   "",                    DID_FILENAME_ED,         4, 164, 311,  8,
                     ES_MARGIN | ES_AUTOSCROLL | WS_GROUP | WS_TABSTOP
        AUTOCHECKBOX "Read-Only",           DID_READ_ONLY,         162, 174, 153,  8

        LTEXT        "Drive:",              DID_DRIVE_TXT,           3, 151,  66,  8
        COMBOBOX     "",                    DID_DRIVE_CB,            3,  18, 154, 133,
                     CBS_DROPDOWNLIST | WS_GROUP | WS_TABSTOP

        LTEXT        "Show files of type:", DID_FILTER_TXT,        162, 151, 128,  8
        COMBOBOX     "",                    DID_FILTER_CB,         162,  18, 154, 133,
                     CBS_DROPDOWN | WS_GROUP | WS_TABSTOP

        LTEXT        "Directory:",          DID_DIRECTORY_TXT,       3, 130,  64,  8
        LTEXT        "",                    DID_DIRECTORY_SELECTED, 69, 130,  88,  8
        LISTBOX                             DID_DIRECTORY_LB,        3,  18, 153, 111,
                     LS_OWNERDRAW | LS_NOADJUSTPOS | LS_HORZSCROLL | WS_TABSTOP

        LTEXT        "File:",               DID_FILES_TXT,         162, 130,  64,  8
        LISTBOX                             DID_FILES_LB,          162,  18, 153, 111,
                     LS_NOADJUSTPOS | LS_HORZSCROLL | WS_TABSTOP

        DEFPUSHBUTTON "~OK",                DID_OK,                  3,   2,  40, 12,
                     WS_GROUP | WS_TABSTOP
        PUSHBUTTON   "Cancel",              DID_CANCEL,             45,   2,  40, 12
        PUSHBUTTON   "Help",                DID_HELP_PB,            87,   2,  40, 12,
                     BS_HELP | BS_NOPOINTERFOCUS
        PUSHBUTTON   "~Apply",              DID_APPLY_PB,          129,   2,  40, 12
    END
END

/* ================================================================== */
/*  Font dialog  (DID_FONT_DIALOG = 300)                               */
/* ================================================================== */
/* Geometry, control set, ids, classes and styles reconstructed to match the
 * original template (dialog 236x116, 21 controls). Name/Style/Size are
 * COMBOBOXes (not entryfield+listbox); Display/Printer and the emphasis
 * options are autocheckboxes; two overlapping ISO-compliance statics. */
DLGTEMPLATE DID_FONT_DIALOG LOADONCALL MOVEABLE DISCARDABLE
BEGIN
    DIALOG  "Font", DID_FONT_DIALOG, 1, 1, 236, 116,
            FS_NOBYTEALIGN | WS_CLIPSIBLINGS | WS_SAVEBITS,
            FCF_TITLEBAR | FCF_SYSMENU | FCF_DLGBORDER
    BEGIN
        LTEXT        "Name",       DID_NAME_PREFIX,        3, 105,  26,  8
        COMBOBOX     "",           DID_NAME,               3,  26, 158, 79,
                     CBS_SIMPLE | WS_GROUP | WS_TABSTOP
        LTEXT        "Style",      DID_STYLE_PREFIX,       3,  86,  26,  8
        COMBOBOX     "",           DID_STYLE,              3,  16, 158, 70,
                     CBS_SIMPLE | WS_GROUP | WS_TABSTOP
        LTEXT        "Size",       DID_SIZE_PREFIX,      166, 105,  63,  8
        COMBOBOX     "",           DID_SIZE,             166,  30,  66, 75,
                     CBS_SIMPLE | WS_GROUP | WS_TABSTOP

        AUTOCHECKBOX "~Display",   DID_DISPLAY_FILTER,   170,  80,  50, 10,
                     WS_GROUP | WS_TABSTOP
        AUTOCHECKBOX "~Printer",   DID_PRINTER_FILTER,   170,  70,  50, 10

        GROUPBOX     "Emphasis",   DID_EMPHASIS_GROUPBOX, 166, 29,  66, 40
        AUTOCHECKBOX "Out~line",   DID_OUTLINE,          170,  51,  59, 10
        AUTOCHECKBOX "~Underline", DID_UNDERSCORE,       170,  41,  59, 10
        AUTOCHECKBOX "~Strikeout", DID_STRIKEOUT,        170,  31,  59, 10

        DEFPUSHBUTTON "~OK",       DID_OK,                 3,   2,  45, 13,
                     WS_GROUP | WS_TABSTOP
        PUSHBUTTON   "Cancel",     DID_CANCEL,            49,   2,  45, 13
        PUSHBUTTON   "Help",       DID_HELP_BUTTON,       95,   2,  45, 13,
                     BS_HELP | BS_NOPOINTERFOCUS
        PUSHBUTTON   "~Apply",     DID_APPLY_BUTTON,     141,   2,  45, 13
        PUSHBUTTON   "~Reset",     DID_RESET_BUTTON,     187,   2,  45, 13

        GROUPBOX     "Sample",     DID_SAMPLE_GROUPBOX,    4,  29, 158, 40
        LTEXT        "abcdABCD",   DID_SAMPLE,             6,  30, 154, 31
        LTEXT        "Font is not ISO-compliant",   DID_FONT_ISO_SUPPORT,  5, 18, 230, 8
        LTEXT        "Font may not be ISO-compliant", DID_FONT_ISO_UNTESTED, 5, 18, 230, 8
    END
END

