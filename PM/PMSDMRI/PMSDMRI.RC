/* ================================================================== */
/*  Print dialog (600). Copies/From/To are spin buttons; the queue is  */
/*  a list. Spin buttons use the generic CONTROL form (WC_SPINBUTTON). */
/* ================================================================== */
DLGTEMPLATE 600 LOADONCALL MOVEABLE DISCARDABLE
BEGIN
    DIALOG  "Print", 600, 64, 34, 259, 188,
            FS_NOBYTEALIGN | WS_CLIPSIBLINGS | WS_SAVEBITS,
            FCF_TITLEBAR | FCF_SYSMENU | FCF_DLGBORDER
    BEGIN
        GROUPBOX     "Print Queue",         IDC_PR_QUEUE_GB,     3, 104, 252, 81
        LISTBOX                             IDC_PR_QUEUE_LB,     9, 126, 242, 49,
                     WS_GROUP | WS_TABSTOP
        PUSHBUTTON   "~Job Properties ...", IDC_PR_JOBPROPS,   164, 108,  88, 12
        GROUPBOX     "Options",             IDC_PR_OPT_GB,       3,  61, 252, 40
        LTEXT        "Copies:",             IDC_PR_COPIES_TXT,   7,  77,  34,  8
        CONTROL      "",  IDC_PR_COPIES_SPIN, 46, 78, 36, 12, WC_SPINBUTTON,
                     SPBS_MASTER | SPBS_NUMERICONLY | WS_GROUP | WS_TABSTOP | WS_VISIBLE
        LTEXT        "",                    IDC_PR_STATUS1,      7,  64, 110,  8
        LTEXT        "",                    IDC_PR_STATUS2,    122,  64, 110,  8
        LTEXT        "",                    IDC_PR_STATUS3,    122,  74, 110,  8
        LTEXT        "",                    IDC_PR_STATUS4,    122,  84, 110,  8
        GROUPBOX     "Print Range",         IDC_PR_RANGE_GB,     3,  18, 252, 40
        AUTORADIOBUTTON "~All",             IDC_PR_ALL,          7,  41,  60,  8,
                     WS_GROUP | WS_TABSTOP
        AUTORADIOBUTTON "~Selection",       IDC_PR_SELECTION,    7,  31,  60,  8
        AUTORADIOBUTTON "Pag~es",           IDC_PR_PAGES,        7,  21,  60,  8
        LTEXT        "From:",               IDC_PR_FROM_TXT,    72,  23,  34, 10
        CONTROL      "",  IDC_PR_FROM_SPIN, 108, 24, 36, 12, WC_SPINBUTTON,
                     SPBS_MASTER | SPBS_NUMERICONLY | WS_TABSTOP | WS_VISIBLE
        LTEXT        "To:",                 IDC_PR_TO_TXT,     148,  23,  28, 10
        CONTROL      "",  IDC_PR_TO_SPIN,   178, 24, 36, 12, WC_SPINBUTTON,
                     SPBS_MASTER | SPBS_NUMERICONLY | WS_TABSTOP | WS_VISIBLE
        DEFPUSHBUTTON "~Print",             DID_OK,              3,   2,  40, 12,
                     WS_GROUP | WS_TABSTOP
        PUSHBUTTON   "P~review",            IDC_PR_PREVIEW,     45,   2,  40, 12
        PUSHBUTTON   "Cancel",              DID_CANCEL,         87,   2,  40, 12
        PUSHBUTTON   "Help",                IDC_PR_HELP,       129,   2,  40, 12,
                     BS_HELP | BS_NOPOINTERFOCUS
    END
END

/* ================================================================== */
/*  File dialog string table -- FUNCTIONAL values. These are WinFileDlg */
/*  protocol constants (path markers, wildcards, separators); they MUST */
/*  match the originals exactly or WinFileDlg's path/filter logic fails  */
/*  (which was why File->Open silently failed). Values verified against  */
/*  the original resource with tools/extract_res.py. Note 1023 is the    */
/*  raw sentinel byte 0x10 (octal \020), not a printable character.      */
/* ================================================================== */
STRINGTABLE
BEGIN
    IDS_FILE_ALL_FILES_SELECTOR  "<All Files>"
    IDS_FILE_BACK_CUR_PATH       ".\\"
    IDS_FILE_BACK_PREV_PATH      "..\\"
    IDS_FILE_BACK_SLASH          "\\"
    IDS_FILE_BASE_FILTER         "*.*"
    IDS_FILE_BLANK               " "
    IDS_FILE_COLON               ":"
    IDS_FILE_DOT                 "."
    IDS_FILE_DRIVE_LETTERS       "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    IDS_FILE_FWD_CUR_PATH        "./"
    IDS_FILE_FWD_PREV_PATH       "../"
    IDS_FILE_FORWARD_SLASH       "/"
    IDS_FILE_PARENT_DIR          ".."
    IDS_FILE_Q_MARK              "?"
    IDS_FILE_SPLAT               "*"
    IDS_FILE_SPLAT_DOT           "*."
    IDS_FILE_SAVEAS_TITLE        "Save as"
    IDS_FILE_SAVEAS_FILTER_TXT   "Save file as type:"
    IDS_FILE_SAVEAS_FILENM_TXT   "Save as filename:"
    IDS_FILE_DUMMY_FILE_NAME     "fn."
    IDS_FILE_DUMMY_FILE_EXT      "ext"
    IDS_FILE_DUMMY_DRIVE         "c:\\"
    IDS_FILE_DUMMY_ROOT_DIR      "\\"
    IDS_FILE_PATH_PTR            "\020"
    IDS_FILE_VOLUME_PREFIX       "  ["
    IDS_FILE_VOLUME_SUFFIX       "]"
    IDS_FILE_PATH_PTR2           ">"
    IDS_FILE_INVALID_CHARS       "|<>\042"
    IDS_FILE_ETC_BACK_SLASH      "\\..."
    IDS_FILE_OPEN_PARENTHESIS    "("
    IDS_FILE_CLOSE_PARENTHESIS   ")"
    IDS_FILE_SEMICOLON           ";"
END

/* File dialog error / note messages (exact original text). */
STRINGTABLE
BEGIN
    IDS_FILE_BAD_DRIVE_NAME          "Invalid drive name specified."
    IDS_FILE_BAD_DRIVE_OR_PATH_NAME  "Invalid drive or sub-directory name specified."
    IDS_FILE_BAD_FILE_NAME           "Invalid file name specified."
    IDS_FILE_BAD_FQF                 "Invalid drive, path, or file."
    IDS_FILE_BAD_NETWORK_NAME        "Invalid network identifier specified."
    IDS_FILE_BAD_SUB_DIR_NAME        "Invalid sub-directory name specified."
    IDS_FILE_DRIVE_NOT_AVAILABLE     "The specified drive is not available on your system."
    IDS_FILE_FQFNAME_TOO_LONG        "Fully qualified filename is too long."
    IDS_FILE_OPEN_DIALOG_NOTE        "Open Dialog Notification"
    IDS_FILE_PATH_TOO_LONG           "Path too long."
    IDS_FILE_SAVEAS_DIALOG_NOTE      "Save As Dialog Notification"
    IDS_FILE_DRIVE_NOT_READY         "Drive %1 not ready."
    IDS_FILE_DRIVE_LOCKED            "Drive %1 Locked or in use."
    1124                             "Drive %1 Disk Unreadable."
    IDS_FILE_DRIVE_SOME_ERROR        "Drive %1 Disk Error.  ID = %2."
    IDS_FILE_DRIVE_INVALID           "Drive %1 is an invalid drive name."
    IDS_FILE_INSERT_DISK_NOTE        "Insert the diskette for Drive %1"
    IDS_FILE_OK_WHEN_READY           "Select OK when ready."
    1130                             "%4 file does not exist.  Create the file?"
    1131                             "%3 path does not exist.  Please verify that the correct path is given."
    1132                             "Cannot find file %4.  Please verify that the correct path and filename are given."
    1133                             "%4 file is already in use.  Use a new filename or close the file in use by another application."
    1134                             "DOS critical error.  Cannot access file %4."
    1135                             "%4 file already exists.  Replace existing file?"
END

