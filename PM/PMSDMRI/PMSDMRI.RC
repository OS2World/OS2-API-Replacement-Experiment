/*
 * PMSDMRI.RC -- OS/2 PM Standard Dialogs MRI (clean-room re-authoring)
 *
 * Recreates the resources of PMSDMRI.DLL from the PUBLIC OS/2 Toolkit
 * definitions in <pmstddlg.h> (INCL_WINSTDFILE / INCL_WINSTDFONT). No bytes
 * were copied from IBM's binary; every dialog control and string is referenced
 * by its documented DID_ and IDS_ identifier so the templates line up with what
 * PM's WinFileDlg / WinFontDlg code loads and manipulates by id.
 *
 * Covered: the File Open/Save-As dialog (DID_FILE_DIALOG, 256) and the Font
 * dialog (DID_FONT_DIALOG, 300), plus the file/font string tables. The
 * functional strings (wildcards, separators, drive letters) carry their real
 * values so filtering/path building work.
 *
 * The two dialog templates were made GEOMETRY-FAITHFUL: their control set,
 * ids, classes, styles and x/y/cx/cy were read from the original template's
 * structure (parsed with tools/extract_res.py, not copied byte-for-byte) and
 * re-authored here. So the File dialog is 319x185 with 16 controls and the
 * Font dialog is 236x116 with 21 controls -- matching the originals. Note the
 * Font dialog's Name/Style/Size are COMBOBOXes (not entryfield+listbox).
 *
 * Also reconstructed (geometry-faithful, internal control ids named locally):
 * 320 Font+Color, 500 Find, 501 Replace, 600 Print. The 1027 "Edit Color"
 * picker (71 controls, marker/position pseudo-controls, DBCS text) is NOT
 * reconstructed -- it is very complex and off the standard File/Font path.
 */

#define INCL_WINSTDFILE
#define INCL_WINSTDFONT
#define INCL_WINDIALOGS
#define INCL_WINSYS
#define INCL_WINLISTBOXES
#define INCL_WINSPINBUTTONCONTROL
#include <os2.h>
#include <pmstddlg.h>

/* Internal control ids for the secondary dialogs (320/500/501/600); these are
 * NOT in the public toolkit header, so they are named locally here. */
