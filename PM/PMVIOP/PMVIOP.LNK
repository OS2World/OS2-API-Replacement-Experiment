# PMVIOP.LNK -- OpenWatcom WLINK for PMVIOP.DLL (32-bit stub)
#
# Build:
#   wcc386 -bt=OS2 -bm -wx -s -fo=PMVIOP.OBJ PMVIOP.C
#   wlink @PMVIOP.LNK
#
# Note: ordinal gaps (9, 38, 44-45, 48, 50-51, 55, 109, 113, 115)
# are intentional -- those ordinals were never assigned in the original.

SYSTEM os2v2 dll initinstance

NAME PMVIOP.DLL

FILE PMVIOP.OBJ

LIB os2386.lib

OPTION ELIMINATE
OPTION OSNAME='OS/2 and ArcaOS'
OPTION DESCRIPTION 'OS/2 PM Internal VIO Support Library'
OPTION MAP=PMVIOP.MAP

# Function exports
EXPORT WINCREATECONSOLE.1
EXPORT WINDESTROYCONSOLE.2
EXPORT WINSYNCWITHPS.3
EXPORT WINCONSOLEOPENKBD.4
EXPORT WINCONSOLECLOSEKBD.5
EXPORT WINCONSOLESETSTATUS.6
EXPORT WINCONSOLEGETSTATUS.7
EXPORT WINCONSOLESETCP.8
EXPORT WINCONSOLEGETCP.10
EXPORT WINCONSOLEKBDXLATE.11
EXPORT WINCONSOLESETCUSTXT.12
EXPORT WINCONSOLEGETFOCUS.13
EXPORT WINCONSOLEFREEFOCUS.14
EXPORT WINCONSOLEREADKEYEVENT.15
EXPORT WINCONSOLEFLUSHKEYEVENTS.16
EXPORT WINCONSOLEQUEUEDPOINTEREVENTS.17
EXPORT WINCONSOLEREADPOINTEREVENT.18
EXPORT WINCONSOLEFLUSHPOINTEREVENTS.19
EXPORT WINCONSOLEGETPOINTERFILTERMASK.20
EXPORT WINCONSOLESETPOINTERFILTERMASK.21
EXPORT WINCONSOLEGETPTRPOS.22
EXPORT WINCONSOLESETPTRPOS.23
EXPORT WINSHIELDABORT.24
EXPORT SHIELDFRAMEPROC.25
EXPORT VIOSHIELDWINDOWPROC.26
EXPORT LOCKVIOPS.27
EXPORT UNLOCKVIOPS.28
EXPORT MARKINGWINDOWPROC.29
EXPORT WINDEFAVIOWINDOWPROC.30
EXPORT WINCONSOLEGETKBDHANDLE.31
EXPORT WINCONSOLEATTACHMOUSEUSER.32
EXPORT WINCONSOLEDETACHMOUSEUSER.33
EXPORT TASKMGRSUBCLASSPROC.34
EXPORT WINSHIELDPRETHAW.35
EXPORT WININITSHIELD.36
EXPORT MORTICIAN.37
EXPORT UNLOCKSEMAPHORES.39
EXPORT CLEARDATA.40
EXPORT QUERYCONSOLE.41
EXPORT MAKEVISIBLE.42
EXPORT GETPASTECHAR.43
EXPORT TERMINATECLIPDDE.46
EXPORT VDMCLIPDDENOTIFY.47
EXPORT PM32CLIPDDENOTIFY.49
EXPORT NOTIFYALLVDMS.52
EXPORT VDMSWAPBUTTONNOTIFY.53
EXPORT GET32DISPLAYTYPE.54
EXPORT VDMREGISTERHOOK.56
EXPORT VDMDEREGISTERHOOK.57

# Data exports (shared ULONG variables)
EXPORT SCREENGROUPTOFPCONSOLE.101
EXPORT APFNVDMSERV.102
EXPORT GETSELACCESS.103
EXPORT NPSZSTRINGS.104
EXPORT KEYBOARDEVENT.105
