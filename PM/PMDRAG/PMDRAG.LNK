# PMDRAG.LNK -- OpenWatcom WLINK for PMDRAG.DLL (32-bit forwarder)
#
# Build:
#   wcc386 -bt=OS2 -bm -wx -s -fo=PMDRAG.OBJ PMDRAG.C
#   wlink @PMDRAG.LNK
#
# PMDRAG.DLL is a pure forwarder: all 33 exports call through to
# PMCTLS.DLL ordinals 41-73. The original binary has zero code pages.
# Our C stubs are thin wrappers; the Drg* calls resolve to PMCTLS
# via os2386.lib / pmctls.lib from the OS/2 Toolkit.

SYSTEM os2v2 dll initinstance

NAME PMDRAG.DLL

FILE PMDRAG.OBJ

OPTION ELIMINATE
OPTION OSNAME='OS/2 and ArcaOS'
OPTION DESCRIPTION 'PM Drag and Drop 16-bit thunk forwarder'
OPTION MAP=PMDRAG.MAP

LIB os2386.lib

# Exports -- ordinals match the original exactly.
# Ordinal gap 32-62 is intentional (matches original binary).
EXPORT DRG16ACCESSDRAGINFO.1
EXPORT DRG16ADDSTRHANDLE.2
EXPORT DRG16ALLOCDRAGINFO.3
EXPORT DRG16ALLOCDRAGTRANSFER.4
EXPORT DRG16DELETEDRAGINFOSTRHANDLES.5
EXPORT DRG16DELETESTRHANDLE.6
EXPORT DRG16DRAG.7
EXPORT DRG16FREEDRAGINFO.8
EXPORT DRG16FREEDRAGTRANSFER.9
EXPORT DRG16GETPS.10
EXPORT DRG16POSTTRANSFERMSG.11
EXPORT DRG16PUSHDRAGINFO.12
EXPORT DRG16QUERYDRAGITEM.13
EXPORT DRG16QUERYDRAGITEMCOUNT.14
EXPORT DRG16QUERYDRAGITEMPTR.15
EXPORT DRG16QUERYNATIVERMF.16
EXPORT DRG16QUERYNATIVERMFLEN.17
EXPORT DRG16QUERYSTRNAME.18
EXPORT DRG16QUERYSTRNAMELEN.19
EXPORT DRG16QUERYTRUETYPE.20
EXPORT DRG16QUERYTRUETYPELEN.21
EXPORT DRG16RELEASEPS.22
EXPORT DRG16SENDTRANSFERMSG.23
EXPORT DRG16SETDRAGPOINTER.24
EXPORT DRG16SETDRAGIMAGE.25
EXPORT DRG16SETDRAGITEM.26
EXPORT DRG16VERIFYNATIVERMF.27
EXPORT DRG16VERIFYRMF.28
EXPORT DRG16VERIFYTRUETYPE.29
EXPORT DRG16VERIFYTYPE.30
EXPORT DRG16VERIFYTYPESET.31
# ords 32-62 intentionally absent (gap matches original binary)
EXPORT DRG16DRAGFILES.63
EXPORT DRG16ACCEPTDROPPEDFILES.64 = DRG16ACCEPTDROPPEDFILESStub
