# DDNSRES.LNK -- OpenWatcom WLINK for DDNSRES.DLL
#
# Build:
#   wcc386 -bt=OS2 -bm -wx -s -fo=DDNSRES.OBJ DDNSRES.C
#   wlink @DDNSRES.LNK
#
# Original: 289606 bytes, TCP/IP 4.3, 57 exports
# Imports: TCPIP32, DOSCALLS, NLS, MSG

SYSTEM os2v2 dll initinstance

NAME DDNSRES.DLL

FILE DDNSRES.OBJ

OPTION DESCRIPTION 'TCP/IP for OS/2: DYNAMIC DNS DLL'
OPTION MAP=DDNSRES.MAP

# Force import chain matching original
IMPORT _dos_ref     DOSCALLS.257
IMPORT _tcpip_ref   TCPIP32.1
IMPORT _nls_ref     NLS.1112
IMPORT _msg_ref     MSG.1

