# DDNSRES_MAKEFILE -- Build DDNSRES.DLL with OpenWatcom on OS/2 Warp 4.52
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: DDNSRES.DLL
DDNSRES.DLL: DDNSRES.OBJ DDNSRES.LNK
	$(LINK) @DDNSRES.LNK
	@echo Build complete: DDNSRES.DLL
DDNSRES.OBJ: DDNSRES.C
	$(CC) $(CFLAGS) -fo=DDNSRES.OBJ DDNSRES.C
clean: .SYMBOLIC
	-$(RM) DDNSRES.OBJ 2>NUL
	-$(RM) DDNSRES.DLL 2>NUL
	-$(RM) DDNSRES.MAP 2>NUL
