# DHCPMRES_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: DHCPMRES.DLL
DHCPMRES.DLL: DHCPMRES.OBJ DHCPMRES.LNK
	$(LINK) @DHCPMRES.LNK
	@echo Build complete: DHCPMRES.DLL
DHCPMRES.OBJ: DHCPMRES.C
	$(CC) $(CFLAGS) -fo=DHCPMRES.OBJ DHCPMRES.C
clean: .SYMBOLIC
	-$(RM) DHCPMRES.OBJ 2>NUL
	-$(RM) DHCPMRES.DLL 2>NUL
	-$(RM) DHCPMRES.MAP 2>NUL
