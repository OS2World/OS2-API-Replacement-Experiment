# Group 6 -- NLS 16-bit wrappers (ords 200-204)
EXPORT  NLS16CONVERTBIDISTRING.200      = NLS16CONVERTBIDISTRING         RESIDENT
EXPORT  NLS16EDITSHAPE.201              = NLS16EDITSHAPE                 RESIDENT
EXPORT  NLS16INVERSESTRING.202          = NLS16INVERSESTRING             RESIDENT
EXPORT  NLS16SHAPEBIDISTRING.203        = NLS16SHAPEBIDISTRING           RESIDENT
EXPORT  NLS16CONVERTBIDINUMERICS.204    = NLS16CONVERTBIDINUMERICS       RESIDENT

# Group 7 -- Nls32 bidi string operations (ords 205-209)
EXPORT  Nls32ConvertBidiString.205      = Nls32ConvertBidiString         RESIDENT
EXPORT  Nls32EditShape.206              = Nls32EditShape                 RESIDENT
