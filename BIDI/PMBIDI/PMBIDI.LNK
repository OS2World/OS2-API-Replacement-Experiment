EXPORT  GPI16SETBIDIATTR.40             = GPI16SETBIDIATTR               RESIDENT
EXPORT  GPI16QUERYBIDIATTR.41           = GPI16QUERYBIDIATTR             RESIDENT
EXPORT  Gpi32SetBidiAttr.50             = Gpi32SetBidiAttr               RESIDENT
