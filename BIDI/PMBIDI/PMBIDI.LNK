# Group 5 -- Settings / Keyword conversion
EXPORT  PMBIDI_Get_StdDlgLang_Setting.101       = PMBIDI_Get_StdDlgLang_Setting         RESIDENT
EXPORT  PMBIDI_16GET_STDDLGLANG_SETTING.102     = PMBIDI_16GET_STDDLGLANG_SETTING       RESIDENT
EXPORT  PMBIDI_String_To_BinVal.110             = PMBIDI_String_To_BinVal               RESIDENT
EXPORT  PMBIDI_BinVal_To_String.111             = PMBIDI_BinVal_To_String               RESIDENT
EXPORT  PMBIDI_Keyword_To_BinVal.112            = PMBIDI_Keyword_To_BinVal              RESIDENT
