# PMBIDI.LNK  --  OpenWatcom WLINK response file for PMBIDI.DLL
#
# Build sequence:
#   wcc386 -bt=OS2 -bm -6s -fpi87 -sg -otexanr -wx -fo=PMBIDI.OBJ PMBIDI.C
#   wlink @PMBIDI.LNK
#
# Compiler flag notes:
#   -bt=OS2    target OS/2
#   -bm        multi-thread safe code generation (implied by DLL target)
#   -6s        i686 instruction set, stack calling convention
#   -fpi87     inline x87 FPU instructions
#   -sg        merge data segments
#   -otexanr   optimise: loop unroll, expand inline, no aliasing, reorder
#   -wx        maximum warnings
#   -s         omit stack checks (avoids pulling in __CHK; optional but keeps DLL lean)
#
# Linker notes:
#   SYSTEM os2v2_dll INITINSTANCE TERMINSTANCE
#     -> selects LX DLL format, causes dllstart.obj from clib3s.lib to be
#        linked automatically; that stub calls LibMain() on each process
#        attach (INITINSTANCE) and detach (TERMINSTANCE).
#   # OPTION start=LibMain_
#     -> DO NOT set start= for OS/2 DLLs: the SYSTEM directive already
#        establishes __DLLstart_ as the true entry point.
#   # OPTION nodefaultlibs
#     -> DO NOT suppress default libs: clib3s.lib (C runtime) and
#        os2386.lib (OS/2 API stubs) must be pulled in automatically by
#        the SYSTEM directive to resolve __DLLstart_, __CHK, etc.
#   OPTION ELIMINATE
#     -> remove unreferenced segments; keeps DLL small.
#   OPTION MANYAUTODATA
#     -> each process gets its own copy of the data segment (needed
#        because we have per-process state in g_LangInfo, etc.).

SYSTEM os2v2_dll INITINSTANCE TERMINSTANCE

NAME PMBIDI.DLL

FILE PMBIDI.OBJ

OPTION ELIMINATE
OPTION MANYAUTODATA
OPTION OSNAME='OS/2 and ArcaOS'
OPTION DESCRIPTION 'OS/2 PM Bidirectional Language APIs'

# Map file for debugging
OPTION MAP=PMBIDI.MAP

# -----------------------------------------------------------------------
# EXPORTS
#
# Syntax:  EXPORT  internal_name.ordinal  [= external_name]  [RESIDENT]
#
# RESIDENT keeps the name in the resident name table (fast lookup).
# Names without RESIDENT go into the non-resident name table (original
# DLL used non-resident names for most exports -- we make them all
# resident for better compatibility and to match how callers resolve them).
#
# Ordinal assignments verified against the original binary's non-resident
# name table.
# -----------------------------------------------------------------------

# Group 1 -- Initialisation
EXPORT  PMBIDI_Initialize.1             = PMBIDI_Initialize             RESIDENT

# Group 2 -- LangInfo / KbdLayer / LangViewer  (16-bit wrappers, ords 10-19)
EXPORT  WIN16SETLANGINFO.10             = WIN16SETLANGINFO               RESIDENT
EXPORT  WIN16QUERYLANGINFO.11           = WIN16QUERYLANGINFO             RESIDENT
EXPORT  WIN16SETKBDLAYER.12             = WIN16SETKBDLAYER               RESIDENT
EXPORT  WIN16QUERYKBDLAYER.13           = WIN16QUERYKBDLAYER             RESIDENT
EXPORT  WIN16SETLANGVIEWER.14           = WIN16SETLANGVIEWER             RESIDENT
EXPORT  WIN16QUERYLANGVIEWER.15         = WIN16QUERYLANGVIEWER           RESIDENT
EXPORT  WIN16SETPROCESSLANGINFO.18      = WIN16SETPROCESSLANGINFO        RESIDENT
EXPORT  WIN16QUERYPROCESSLANGINFO.19    = WIN16QUERYPROCESSLANGINFO      RESIDENT

# Group 2 -- LangInfo / KbdLayer / LangViewer  (32-bit, ords 20-31)
EXPORT  Win32SetLangInfo.20             = Win32SetLangInfo               RESIDENT
EXPORT  Win32QueryLangInfo.21           = Win32QueryLangInfo             RESIDENT
EXPORT  Win32SetKbdLayer.22             = Win32SetKbdLayer               RESIDENT
EXPORT  Win32QueryKbdLayer.23           = Win32QueryKbdLayer             RESIDENT
EXPORT  Win32SetLangViewer.24           = Win32SetLangViewer             RESIDENT
EXPORT  Win32QueryLangViewer.25         = Win32QueryLangViewer           RESIDENT
EXPORT  Win32SetProcessLangInfo.30      = Win32SetProcessLangInfo        RESIDENT
EXPORT  Win32QueryProcessLangInfo.31    = Win32QueryProcessLangInfo      RESIDENT

