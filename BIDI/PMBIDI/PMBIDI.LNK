# Group 8 -- layout_object (ords 306-311)
EXPORT  layout_object_create.306        = layout_object_create           RESIDENT
EXPORT  layout_object_destroy.307       = layout_object_destroy          RESIDENT
EXPORT  layout_object_transform.308     = layout_object_transform        RESIDENT
EXPORT  layout_object_editshape.309     = layout_object_editshape        RESIDENT
EXPORT  layout_object_setvalues.310     = layout_object_setvalues        RESIDENT
EXPORT  layout_object_getvalues.311     = layout_object_getvalues        RESIDENT

# Group 9 -- Codepage translation (ords 400-401)
EXPORT  PMBIDI_16CP_TRANSLATE_STRING.400 = PMBIDI_16CP_TRANSLATE_STRING  RESIDENT
EXPORT  PMBIDI_CpTranslateString.401    = PMBIDI_CpTranslateString       RESIDENT

# Group 10 -- Advanced bidi (ords 450-454, 460-461)
EXPORT  Bidi_MapSrcToTrg.450            = Bidi_MapSrcToTrg               RESIDENT
EXPORT  Bidi_ClassifyCodepage.451       = Bidi_ClassifyCodepage          RESIDENT
EXPORT  Bidi_IsStringBidi.452           = Bidi_IsStringBidi              RESIDENT
