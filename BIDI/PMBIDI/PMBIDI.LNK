# Group 11 -- Global exported data (ord 999)
# ulProcess_BidiAttr is a ULONG variable exported by name+ordinal.
# wlink syntax for exported data: same EXPORT directive -- the linker
# handles data exports the same as function exports in the LX entry table.
EXPORT  ulProcess_BidiAttr.999          = ulProcess_BidiAttr             RESIDENT
