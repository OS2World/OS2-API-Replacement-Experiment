# WPPRTMRI_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: WPPRTMRI.DLL
WPPRTMRI.DLL: WPPRTMRI.OBJ WPPRTMRI.LNK
	$(LINK) @WPPRTMRI.LNK
	@echo Build complete: WPPRTMRI.DLL
WPPRTMRI.OBJ: WPPRTMRI.C
	$(CC) $(CFLAGS) -fo=WPPRTMRI.OBJ WPPRTMRI.C
clean: .SYMBOLIC
	-$(RM) WPPRTMRI.OBJ 2>NUL
	-$(RM) WPPRTMRI.DLL 2>NUL
	-$(RM) WPPRTMRI.MAP 2>NUL
