# WPCONMRI_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: WPCONMRI.DLL
WPCONMRI.DLL: WPCONMRI.OBJ WPCONMRI.LNK
	$(LINK) @WPCONMRI.LNK
	@echo Build complete: WPCONMRI.DLL
WPCONMRI.OBJ: WPCONMRI.C
	$(CC) $(CFLAGS) -fo=WPCONMRI.OBJ WPCONMRI.C
clean: .SYMBOLIC
	-$(RM) WPCONMRI.OBJ 2>NUL
	-$(RM) WPCONMRI.DLL 2>NUL
	-$(RM) WPCONMRI.MAP 2>NUL
