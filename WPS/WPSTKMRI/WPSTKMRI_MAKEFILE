# WPSTKMRI_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: WPSTKMRI.DLL
WPSTKMRI.DLL: WPSTKMRI.OBJ WPSTKMRI.LNK
	$(LINK) @WPSTKMRI.LNK
	@echo Build complete: WPSTKMRI.DLL
WPSTKMRI.OBJ: WPSTKMRI.C
	$(CC) $(CFLAGS) -fo=WPSTKMRI.OBJ WPSTKMRI.C
clean: .SYMBOLIC
	-$(RM) WPSTKMRI.OBJ 2>NUL
	-$(RM) WPSTKMRI.DLL 2>NUL
	-$(RM) WPSTKMRI.MAP 2>NUL
