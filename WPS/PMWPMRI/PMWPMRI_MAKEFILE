# PMWPMRI_MAKEFILE
CC=wcc386
LINK=wlink
RM=del
CFLAGS=-bt=OS2 -bm -wx -s -ox
all: PMWPMRI.DLL
PMWPMRI.DLL: PMWPMRI.OBJ PMWPMRI.LNK
	$(LINK) @PMWPMRI.LNK
	@echo Build complete: PMWPMRI.DLL
PMWPMRI.OBJ: PMWPMRI.C
	$(CC) $(CFLAGS) -fo=PMWPMRI.OBJ PMWPMRI.C
clean: .SYMBOLIC
	-$(RM) PMWPMRI.OBJ 2>NUL
	-$(RM) PMWPMRI.DLL 2>NUL
	-$(RM) PMWPMRI.MAP 2>NUL
